#!/bin/sh
# Conventional Commits validation hook
# https://www.conventionalcommits.org/
#
# To enable this hook, run:
#   git config core.hooksPath .githooks

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
    exit 0
fi

# Skip squash merge commits (git merge --squash generates this preamble)
if echo "$commit_msg" | grep -qE "^Squashed commit of the following:"; then
    exit 0
fi

# Strip Co-Authored-By lines (we don't want AI co-author attribution)
sed -i '/^Co-Authored-By:/d' "$commit_msg_file"
sed -i '/^co-authored-by:/d' "$commit_msg_file"

# Clean up noise phrases from any commit message (regardless of source)
# Strips suffixes like " — implementation prompt", " — plan", " — spec"
# that leak from kanban card titles into commit messages
sed -i -E 's/ — (implementation prompt|plan|spec|specification|prompt|task description)//i' "$commit_msg_file"
# Strip "(vibe-kanban ISS-XX)" tags anywhere in the message
sed -i -E 's/ *\(vibe-kanban [^)]*\)//g' "$commit_msg_file"
# Re-read after cleanup
commit_msg=$(cat "$commit_msg_file")

# Auto-rewrite vibe-kanban commit messages to conventional format
# Converts: "Task 26: Performance Profiling & Baselines"
# To:       "feat(task-26): performance profiling & baselines"
# Detects both "Task NN:" prefix and "Implement Task NN:" prefix
task_num=$(echo "$commit_msg" | head -1 | sed -nE 's/^(Implement )?Task ([0-9.]+):.*/\2/p')
if [ -n "$task_num" ]; then
    description=$(echo "$commit_msg" | head -1 | sed -E 's/^(Implement )?Task [0-9.]+: //')

    if [ -n "$description" ]; then
        # Lowercase the description
        description=$(echo "$description" | tr '[:upper:]' '[:lower:]')
        # Build conventional commit message
        new_msg="feat(task-${task_num}): ${description}"
        # Preserve any body content (lines after the first)
        body=$(echo "$commit_msg" | tail -n +2)
        if [ -n "$body" ]; then
            printf '%s\n%s\n' "$new_msg" "$body" > "$commit_msg_file"
        else
            printf '%s\n' "$new_msg" > "$commit_msg_file"
        fi
        exit 0
    fi
fi

# Conventional commit pattern:
# type(scope)?: description
#
# Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-zA-Z0-9_-]+\))?(!)?: .{1,}"

if ! echo "$commit_msg" | head -1 | grep -qE "$pattern"; then
    echo ""
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo ""
    echo "Expected format: <type>(<scope>): <description>"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore"
    echo ""
    echo "Examples:"
    echo "  feat(translator): add flash swap ordering"
    echo "  fix(router): handle empty tick arrays"
    echo "  chore(deps): update dependencies"
    echo "  refactor(query-service): extract pool fetching"
    echo ""
    echo "Your commit message was:"
    echo "  $(head -1 "$commit_msg_file")"
    echo ""
    exit 1
fi

# Check description length (should be meaningful, at least 10 chars)
description=$(echo "$commit_msg" | head -1 | sed -E 's/^(feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-zA-Z0-9_-]+\))?(!)?: //')
if [ ${#description} -lt 10 ]; then
    echo ""
    echo "ERROR: Commit description is too short (minimum 10 characters)."
    echo "Your description: '$description'"
    echo ""
    exit 1
fi

exit 0
